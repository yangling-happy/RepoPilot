{
  "name": "my-project-monorepo",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm run dev:all",
    "dev:frontend": "pnpm --filter @repo-pilot/web dev",
    "dev:terminal": "pnpm --filter @repo-pilot/terminal-client dev",
    "dev:backend": "pnpm run dev:backend:prepare && concurrently \"pnpm:dev:backend:business:run\" \"pnpm:dev:backend:terminal:run\"",
    "dev:backend:prepare": "bash -lc \"cd backend && ./mvnw -N install && ./mvnw -f common/pom.xml install -DskipTests\"",
    "dev:backend:business": "pnpm run dev:backend:prepare && pnpm run dev:backend:business:run",
    "dev:backend:business:run": "bash -lc \"cd backend && ./mvnw -f business/pom.xml spring-boot:run -DskipTests\"",
    "dev:backend:terminal": "pnpm run dev:backend:prepare && pnpm run dev:backend:terminal:run",
    "dev:backend:terminal:run": "bash -lc \"cd backend && ./mvnw -f terminal/pom.xml spring-boot:run -DskipTests\"",
    "dev:backend:gateway": "bash -lc \"cd backend && ./mvnw -N install && ./mvnw -f gateway/pom.xml spring-boot:run -DskipTests\"",
    "dev:all": "concurrently \"pnpm:dev:frontend\" \"pnpm:dev:terminal\" \"pnpm:dev:backend\"",
    "build": "pnpm run build:all",
    "build:frontend": "pnpm --filter @repo-pilot/web build",
    "build:terminal": "pnpm --filter @repo-pilot/terminal-client build",
    "build:backend": "cd backend && ./mvnw clean package",
    "build:all": "pnpm run build:frontend && pnpm run build:terminal && pnpm run build:backend",
    "test": "pnpm run test:frontend && pnpm run test:backend",
    "test:frontend": "pnpm --filter @repo-pilot/web test",
    "test:backend": "cd backend && ./mvnw test",
    "lint": "eslint apps --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint apps --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "apps/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "apps/**/*.{css,json}": [
      "prettier --write"
    ],
    "*.{yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@repo-pilot/terminal-client": "workspace:*",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "concurrently": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-i18next": "^6.1.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
