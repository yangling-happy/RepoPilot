# Force LF line endings for shell scripts and Maven wrapper
*.sh text eol=lf
*.bash text eol=lf
mvnw text eol=lf

# Force LF line endings for source code and config files
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.properties text eol=lf

# Force LF line endings for frontend source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf

# Keep CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
mvnw.cmd text eol=crlf
